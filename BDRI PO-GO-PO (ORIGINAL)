<script>
    // ======================= PO GO PO CORE COMPILER =======================
    const commonStops = new Set([
        'a','an','the','and','of','to','in','for','on','with','by','at','from','into','through',
        'during','without','between','this','that','these','those','it','they','we','you','he','she',
        'is','are','was','were','be','been','being','have','has','had','having','do','does','did','doing',
        'but','so','nor','for','yet','also','only','both','each','every','some','any','no',
        'very','really','quite','rather','somewhat','merely','simply','just','actually','basically',
        'literally','often','usually','historically','traditionally','originally','persistently',
        '的','了','是','在','和','与','或','但','因为','所以','尽管','虽然','然而','如果','那么','否则',
        '就','都','也','还','被','把','让','给','有','这','那','不','没','无','很','太','非常','真的','其实'
    ]);

    function toPoGoPo(text) {
        if (!text || text.length < 5) return "low information ~";
        // 条件分支检测 (中英文)
        let ifMatch = text.match(/\bif\s+(.+?)\s*(?:then\s+)?(.+?)(?:\s+else\s+(.+?))?(?:\.|$)/i);
        if (ifMatch) {
            let cond = ifMatch[1].trim(), thenB = ifMatch[2].trim(), elseB = ifMatch[3] ? ifMatch[3].trim() : "";
            return cond + " → " + thenB + (elseB ? " else " + elseB : "") + " ~";
        }
        ifMatch = text.match(/如果\s+(.+?)\s*[，,]\s*(?:那么|则)?\s*(.+?)(?:\s*否则\s*(.+?))?/);
        if (ifMatch) {
            let cond = ifMatch[1].trim(), thenB = ifMatch[2].trim(), elseB = ifMatch[3] ? ifMatch[3].trim() : "";
            return cond + " → " + thenB + (elseB ? " 否则 " + elseB : "") + " ~";
        }
        // 通用清洗
        let cleaned = text.replace(/^(although|though|even though|because|since)\s+/i, '');
        cleaned = cleaned.replace(/,\s*(that|which|where|when|if)?\s*/g, ' · ');
        cleaned = cleaned.replace(/;\s*/g, ' · ');
        cleaned = cleaned.replace(/\s+(that|which|where|when|if)\s+/g, ' · ');
        let words = cleaned.split(/\s+/);
        let filtered = [], neg = false;
        for (let w of words) {
            let lw = w.toLowerCase().replace(/[.,;:!?]$/, '');
            if (lw === 'not' || lw === "n't" || lw === 'no' || lw === 'never') { neg = true; filtered.push(w); }
            else if (!commonStops.has(lw)) filtered.push(w);
        }
        let str = filtered.join(' ');
        let chunks = str.split(/[·.?!]+/);
        let meaningful = [];
        for (let ch of chunks) {
            let term = ch.trim();
            if (term.length < 3) continue;
            let ws = term.split(/\s+/);
            let keep = ws.filter(w => !commonStops.has(w.toLowerCase()));
            if (keep.length === 0) continue;
            let phrase = keep.join(' ');
            if (phrase.length > 2) meaningful.push(phrase);
        }
        if (meaningful.length === 0) {
            let fallback = text.split(/\s+/).filter(w => w.length > 2 && !commonStops.has(w.toLowerCase()) && !/[.,;:!?]/.test(w));
            meaningful = [...new Map(fallback.map(w => [w.toLowerCase(), w])).values()].slice(0,6);
        }
        let unique = [];
        for (let p of meaningful) if (!unique.some(u => u.toLowerCase() === p.toLowerCase())) unique.push(p);
        let final = unique.slice(0,8);
        if (final.length === 0) final = ['concept'];
        let result = final.join(' + ') + ' ~';
        if (neg && !result.toLowerCase().includes('not')) result = 'not + ' + result;
        return result.charAt(0).toUpperCase() + result.slice(1);
    }

    // ======================= FACT EXTRACTION (Logic Looker) =======================
    function extractFacts(text) {
        let lower = text.toLowerCase();
        let facts = {};
        // Name: look for "name is X" or "my name is X" or "I am X" (simplified)
        let nameMatch = text.match(/(?:name is|my name is|I am|called)\s+([A-Z][a-z]+)/i);
        if (nameMatch) facts.name = nameMatch[1];
        // Age: "X years old" or "age X"
        let ageMatch = text.match(/(\d+)\s*(?:years old|year old|years of age)/i);
        if (ageMatch) facts.age = ageMatch[1];
        // Favorite colors: "favorite colors are X, Y and Z"
        let colorMatch = text.match(/favorite colors? (?:are|:)?\s*([a-z]+(?:\s*(?:,|and)\s*[a-z]+)*)/i);
        if (colorMatch) {
            let colors = colorMatch[1].split(/[, ]+and /).flatMap(c => c.split(/,\s*/));
            facts.favoriteColors = colors.map(c => c.trim()).filter(c => c.length);
        }
        return facts;
    }

    // ======================= DECOMPOSITION =======================
    function decompose(chain) {
        let norm = chain.replace(/~$/, '').trim();
        if (norm.includes(' → ')) {
            let parts = norm.split(' → ');
            let cond = parts[0];
            let rest = parts[1];
            let elseIdx = rest.lastIndexOf(' else ');
            if (elseIdx !== -1) {
                return [{ type: 'condition', condition: cond, then: rest.slice(0, elseIdx).trim(), else: rest.slice(elseIdx+5).trim() }];
            } else {
                return [{ type: 'condition', condition: cond, then: rest, else: null }];
            }
        }
        if (norm.includes(' + ')) {
            return norm.split(' + ').map(s => ({ type: 'action', content: s.trim() }));
        }
        return [{ type: 'action', content: norm }];
    }

    // ======================= CODE GENERATION =======================
    function generateCode(blocks) {
        let lines = ["# Auto-generated by PO GO PO\n"];
        for (let b of blocks) {
            if (b.type === 'condition') {
                lines.push(`# Conditional`);
                lines.push(`if ${escapeCond(b.condition)}:`);
                lines.push(`    ${escapeAction(b.then)}`);
                if (b.else) {
                    lines.push(`else:`);
                    lines.push(`    ${escapeAction(b.else)}`);
                }
            } else {
                lines.push(escapeAction(b.content));
            }
        }
        if (lines.length === 2) lines.push("# No actionable logic");
        return lines.join('\n');
    }
    function escapeCond(cond) { return `check_condition("${cond}")`; }
    function escapeAction(act) {
        let a = act.toLowerCase();
        if (a.includes('restart')) return `restart_service()  # Simulated restart`;
        if (a.includes('clear')) return `clear_cache()  # Cache cleared`;
        if (a.includes('send') || a.includes('alert')) return `send_alert("admin@example.com")`;
        if (a.includes('shut')) return `shutdown_reactor()`;
        if (a.includes('keep')) return `keep_running()`;
        return `log_action("${act}")  # Simulated`;
    }

    // ======================= SIMULATION =======================
    let simLog = [];
    function log(msg) { simLog.push(`[${new Date().toLocaleTimeString()}] ${msg}`); }
    function simulateAction(act) {
        let a = act.toLowerCase();
        if (a.includes('restart_service')) log("✅ Service restart simulated");
        else if (a.includes('clear_cache')) log("🗑️ Cache cleared");
        else if (a.includes('send_alert')) log("📧 Alert email sent");
        else if (a.includes('shutdown_reactor')) log("☢️ Reactor shut down");
        else if (a.includes('keep_running')) log("⏳ System continues running");
        else if (a.includes('log_action')) log(`📝 Log: ${act.replace('log_action("','').replace('")','')}`);
        else log(`⚙️ Simulated: ${act.substring(0,50)}`);
    }
    function simulate(blocks) {
        simLog = [];
        for (let b of blocks) {
            if (b.type === 'condition') {
                log(`🔀 Condition: ${b.condition}`);
                let outcome = Math.random() > 0.5;
                if (outcome) {
                    log(`✅ Condition true → executing: ${b.then}`);
                    simulateAction(b.then);
                } else if (b.else) {
                    log(`❌ Condition false → executing else: ${b.else}`);
                    simulateAction(b.else);
                } else {
                    log(`❌ Condition false, no else`);
                }
            } else {
                log(`▶️ Action: ${b.content}`);
                simulateAction(b.content);
            }
        }
        if (simLog.length === 0) log("No actions");
        return simLog.join('\n');
    }

    // ======================= UI BINDINGS =======================
    let currentBlocks = [];

    function compileAndDisplay() {
        let raw = document.getElementById('nlInput').value;
        if (!raw.trim()) {
            document.getElementById('logicChain').innerHTML = "— Enter text —";
            document.getElementById('factsArea').innerHTML = "— —";
            document.getElementById('decompArea').innerHTML = "— —";
            document.getElementById('codeArea').innerHTML = "# No code";
            return;
        }
        let chain = toPoGoPo(raw);
        document.getElementById('logicChain').innerHTML = chain;
        let facts = extractFacts(raw);
        let factsHtml = Object.entries(facts).map(([k,v]) => `${k}: ${Array.isArray(v) ? v.join(', ') : v}`).join('<br>') || "(none)";
        document.getElementById('factsArea').innerHTML = factsHtml;
        let blocks = decompose(chain);
        currentBlocks = blocks;
        let decompHtml = '';
        for (let b of blocks) {
            if (b.type === 'condition')
                decompHtml += `🔀 Condition: ${b.condition}<br>  ↳ true: ${b.then}${b.else ? `<br>  ↳ false: ${b.else}` : ''}<br>`;
            else
                decompHtml += `▸ Action: ${b.content}<br>`;
        }
        document.getElementById('decompArea').innerHTML = decompHtml || "(none)";
        let code = generateCode(blocks);
        document.getElementById('codeArea').innerHTML = code;
        document.getElementById('execLog').innerHTML = "— Click [Simulate Execution] —";
    }

    function runSimulation() {
        if (!currentBlocks.length) {
            document.getElementById('execLog').innerHTML = "No compiled blocks. Compile first.";
            return;
        }
        let result = simulate(currentBlocks);
        document.getElementById('execLog').innerHTML = result;
    }

    function clearLog() {
        document.getElementById('execLog').innerHTML = "— Log cleared —";
        simLog = [];
    }

    function loadExample(type) {
        if (type === 'facts') {
            document.getElementById('nlInput').value = "Hello Sir! My name is Alexander and I am 6 years old. My favourite colors are green or blue.";
        } else if (type === 'ops') {
            document.getElementById('nlInput').value = "If server memory exceeds 80%, clear cache and restart service, then send email alert.";
        }
        compileAndDisplay();
    }

    // Event listeners
    document.getElementById('compileBtn').addEventListener('click', compileAndDisplay);
    document.getElementById('runBtn').addEventListener('click', runSimulation);
    document.getElementById('clearLogBtn').addEventListener('click', clearLog);
    document.getElementById('exampleFacts').addEventListener('click', () => loadExample('facts'));
    document.getElementById('exampleOps').addEventListener('click', () => loadExample('ops'));
    document.getElementById('clearBtn').addEventListener('click', () => {
        document.getElementById('nlInput').value = '';
        compileAndDisplay();
    });

    // Initial load example
    loadExample('facts');
</script>
